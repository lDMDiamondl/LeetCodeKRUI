{
  "manifest_version": 3,
  "name": "LeetCode UI 한글화",
  "version": "1.0.1",
  "description": "LeetCode의 주요 인터페이스와 알고리즘 태그를 한국어로 번역합니다.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.leetcode.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "LeetCode UI 한글화"
  },
  "host_permissions": [
    "*://*.leetcode.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/translations.json"
      ],
      "matches": [
        "*://*.leetcode.com/*"
      ]
    }
  ],
  "permissions": [
    "storage"
  ]
}